
# ═══════════════════════════════════════
# 应用配置
# ═══════════════════════════════════════
APP_ENV=development
DEBUG=true
API_PORT=8001

# ═══════════════════════════════════════
# LLM 配置
# ═══════════════════════════════════════
# 支持 OpenAI 官方 API，或兼容 OpenAI 协议的第三方 API（如阿里云通义千问、DeepSeek 等）
OPENAI_API_KEY=sk-xxx
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# ═══════════════════════════════════════
# MongoDB 配置
# ═══════════════════════════════════════
MONGODB_URL=mongodb://admin:xxx@localhost:27017
MONGODB_DB=myagent

# ═══════════════════════════════════════
# Neo4j 图数据库配置（产业链图谱）
# ═══════════════════════════════════════
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=xxx
NEO4J_DATABASE=neo4j

# ═══════════════════════════════════════
# 上下文管理配置
# ═══════════════════════════════════════
CONTEXT_MAX_TOKENS=8192
CONTEXT_MIN_RECENT=10
CONTEXT_MAX_RECENT=20
CONTEXT_ENABLE_IMPORTANCE=true
CONTEXT_ENABLE_RELEVANCE=false
CONTEXT_RELEVANCE_THRESHOLD=0.3

# ═══════════════════════════════════════
# CORS 配置
# ═══════════════════════════════════════
# 开发环境: 使用 ["*"] 允许所有来源（方便调试）
# 生产环境: 明确指定允许的域名，例如:
# CORS_ORIGINS=["https://yourdomain.com", "https://app.yourdomain.com"]
CORS_ORIGINS=["*"]

# ═══════════════════════════════════════
# 搜索配置
# ═══════════════════════════════════════
# 搜索引擎提供商：tavily（付费，质量高）/ duckduckgo（免费，无需 API key）
SEARCH_PROVIDER=tavily
# 是否启用网络搜索工具
SEARCH_ENABLED=true
# Tavily API Key（SEARCH_PROVIDER=tavily 时必填，duckduckgo 无需填写）
TAVILY_API_KEY=tvly-xxx
# 默认返回结果条数
SEARCH_MAX_RESULTS=3
# 默认搜索深度：basic（快速）/ advanced（详细）
SEARCH_DEPTH=basic

# ═══════════════════════════════════════
# JWT 密钥配置
# ═══════════════════════════════════════
# 生产环境请使用强随机字符串（至少 32 位）
JWT_SECRET_KEY=xxx

# ═══════════════════════════════════════
# 系统提示词配置
# ═══════════════════════════════════════
# 提示词版本号，对应文件: src/core/prompt/system_prompts_v{version}.json
SYSTEM_PROMPT_VERSION=1.0

# ═══════════════════════════════════════
# 对话上下文管理配置
# ═══════════════════════════════════════
# 基础限制
CONV_CTX_MAX_MESSAGES=50
CONV_CTX_MAX_TOKENS=8000

# 摘要压缩配置
CONV_CTX_ENABLE_COMPRESSION=false
CONV_CTX_KEEP_RECENT_MESSAGES=20

# AI 摘要配置
CONV_CTX_ENABLE_AI_SUMMARY=true
CONV_CTX_SUMMARY_MAX_LENGTH=200

# Token 估算配置
CONV_CTX_CHINESE_TOKEN_RATIO=1.5
CONV_CTX_ENGLISH_TOKEN_RATIO=0.75

# ═══════════════════════════════════════
# LangSmith 监控（可选）
# ═══════════════════════════════════════
LANGSMITH_ENABLED=false
LANGSMITH_TRACING=true
LANGCHAIN_API_KEY=lsv2-xxx
LANGSMITH_PROJECT=my-agent
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
